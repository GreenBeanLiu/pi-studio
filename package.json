{
  "name": "pi-studio",
  "version": "0.9.0",
  "description": "Windows desktop client for the Pi coding agent",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "check:text": "node scripts/check-text-encoding.js",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "lint": "eslint --ext .ts,.tsx src tests",
    "check": "pnpm run check:text && pnpm run typecheck && pnpm run test && pnpm run lint",
    "verify": "pnpm run check && pnpm run build",
    "preview": "electron-vite preview",
    "package": "pnpm run verify && electron-builder --win --publish always",
    "release:local": "node scripts/release-local.js",
    "release:dry": "node scripts/release-local.js --dry-run --skip-build"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.80.7",
    "@earendil-works/pi-ai": "^0.80.7",
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@lobehub/ui": "^5.14.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.3.1",
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "dayjs": "^1.11.21",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.1.0",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "cc.glanger.pi-studio",
    "productName": "pi-studio",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "build/icon.ico",
      "!**/*.map",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.{md,markdown,txt}",
      "!node_modules/**/{LICENSE,LICENSE.*,license,CHANGELOG.md,README.md}",
      "resources/pi-skills/**",
      "resources/model-export/**",
      "resources/pi-subagent/**",
      "node_modules/@earendil-works/pi-coding-agent/examples/extensions/subagent/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "GreenBeanLiu",
      "repo": "pi-studio",
      "releaseType": "release"
    },
    "electronDownload": {
      "mirror": "https://github.com/electron/electron/releases/download/"
    }
  },
  "type": "module"
}
